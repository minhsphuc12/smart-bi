# Copy to ".env" in this directory (apps/api/) — file ".env" is gitignored.
# Values here load when the API starts (see app/main.py). Existing OS env vars are not overwritten.

# --- LLM (optional; Ask Data NL2SQL when connection_id is set) ---
# OPENAI_API_KEY=
# SMART_BI_OPENAI_API_KEY=
# SMART_BI_OPENAI_BASE_URL=https://api.openai.com/v1

# ANTHROPIC_API_KEY=
# SMART_BI_ANTHROPIC_API_KEY=

# GOOGLE_API_KEY=
# SMART_BI_GOOGLE_API_KEY=

# --- File-backed data paths (optional overrides) ---
# SMART_BI_CONNECTIONS_FILE=
# SMART_BI_SEMANTIC_FILE=
# SMART_BI_SEMANTIC_MART_DIR=   # optional: folder of *.yml/*.yaml for LLM (default: <repo>/mart/)
# SMART_BI_AI_ROUTING_FILE=
# SMART_BI_DASHBOARDS_FILE=
